# Server
PORT=3000

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cdc_hms
DB_USER=root
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Email (Nodemailer - use Gmail App Password or SMTP provider)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# Password Reset Token (milliseconds - default 1 hour)
RESET_TOKEN_EXPIRES_IN=3600000
